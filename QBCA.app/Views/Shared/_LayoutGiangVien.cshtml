                        <div class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">IA Bert</a>
                            <div class="dropdown-menu m-0">
                                <a href="detail.html" class="dropdown-item">Trả lời câu hỏi trùng lặp</a>
                                <a href="feature.html" class="dropdown-item">Tải câu hỏi</a>
                                <a href="team.html" class="dropdown-item">Tạo đề thi</a>
                                <a href="testimonial.html" class="dropdown-item">Xoá câu hỏi trùng lặp </a>
                            </div>
                        </div>
